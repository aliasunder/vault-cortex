{
  "name": "vault-cortex",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev:mcp": "tsx watch src/vault-mcp/server.ts",
    "start": "node dist/vault-mcp/server.js",
    "dev:sst": "sst dev",
    "deploy": "sst deploy",
    "remove": "sst remove",
    "docker:build": "tsx scripts/dev.mts docker:build",
    "docker:push": "tsx scripts/dev.mts docker:push",
    "docker:publish": "tsx scripts/dev.mts docker:publish",
    "lightsail:up": "tsx scripts/dev.mts lightsail:up",
    "deploy:dev": "npm run deploy && npm run docker:publish && npm run lightsail:up"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.3",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "sst": "^4.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}

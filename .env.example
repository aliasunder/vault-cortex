# MCP bearer token — defense in depth.
# Must be the SAME value as the SST `McpAuthToken` secret (which the
# Lambda authorizer reads). vault-mcp validates this in-process via
# Express middleware so requests that bypass API Gateway and hit the
# Lightsail public IP directly are still rejected.
# Rotation: update the SST secret AND this file, then redeploy both.
MCP_AUTH_TOKEN=

# Obsidian Sync credentials
# Generate OBSIDIAN_AUTH_TOKEN once with:
#   docker run --rm -it --entrypoint get-token \
#     ghcr.io/belphemur/obsidian-headless-sync-docker:latest
OBSIDIAN_AUTH_TOKEN=
VAULT_NAME=My Vault
VAULT_PASSWORD=              # only if vault has E2E encryption

# Docker
GHCR_USER=aliasunder
VAULT_MCP_TAG=latest
PUID=1000
PGID=1000
DEVICE_NAME=vault-cortex-lightsail
CONFLICT_STRATEGY=merge
SYNC_MODE=bidirectional
LOG_LEVEL=info
TZ=America/New_York

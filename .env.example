# Secrets file — lives at ~/.config/vault-cortex/.env (NOT in the repo).
# Copy this template there and fill in values:
#   mkdir -p ~/.config/vault-cortex
#   cp .env.example ~/.config/vault-cortex/.env
#   chmod 600 ~/.config/vault-cortex/.env
#
# MCP bearer token — used by the Express OAuth provider for:
# 1. Static bearer token auth (backward compat with CLI tools)
# 2. Consent page password (user enters this to approve OAuth clients)
# Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Public URL — the HTTPS URL that MCP clients use to reach this server.
# Used as the OAuth issuer URL in discovery metadata.
# Usually your API Gateway URL (from `sst deploy` outputs).
PUBLIC_URL=

# Obsidian Sync credentials
# Generate OBSIDIAN_AUTH_TOKEN once with:
#   docker run --rm -it --entrypoint get-token \
#     ghcr.io/belphemur/obsidian-headless-sync-docker:latest
OBSIDIAN_AUTH_TOKEN=
VAULT_NAME=
VAULT_PASSWORD=              # only if vault has E2E encryption
GHCR_TOKEN=

# Lightsail SSH — used by `npm run lightsail:up` for SCP/SSH.
# Defaults to ~/.ssh/vault-cortex (the dedicated deploy key).
# Both local dev and CI use the same key to avoid instance replacement.
# Generate once: ssh-keygen -t ed25519 -f ~/.ssh/vault-cortex -C vault-cortex-deploy
# LIGHTSAIL_SSH_KEY=~/.ssh/vault-cortex

# Docker
GHCR_USER=
PUID=1000
PGID=1000
DEVICE_NAME=vault-cortex-lightsail
CONFLICT_STRATEGY=merge
SYNC_MODE=bidirectional
LOG_LEVEL=info
TZ=UTC

# AWS region — only used by SST deploys (sst.config.ts). Ignored by Docker containers.
# AWS_REGION=us-east-1

# vault-cortex configuration
# Memory folder name in your vault (default: "About Me")
MEMORY_DIR=About Me
# Comma-separated folders protected from deletion (default: MEMORY_DIR, Daily Notes).
# If your daily notes folder has a custom name (e.g. "Journal"), override to include it.
# PROTECTED_PATHS=About Me,Daily Notes
# Comma-separated folders excluded from orphan detection (default: Daily Notes, Templates, MEMORY_DIR)
# ORPHAN_EXCLUDE_FOLDERS=Daily Notes,Templates,About Me
# URL shown in OAuth discovery metadata (default: https://github.com/aliasunder/vault-cortex)
# SERVICE_DOCUMENTATION_URL=https://github.com/youruser/your-fork
